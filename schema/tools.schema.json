{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CloudGuardrail Tool Directory Entry",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["name", "website", "category", "clouds", "type", "distinct", "compliance"],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 2
      },
      "website": {
        "type": "string",
        "pattern": "^https://"
      },
      "category": {
        "type": "string",
        "enum": [
          "CSPM",
          "CNAPP",
          "IaC Security",
          "Secrets Scanning",
          "Container Security",
          "Compliance as Code",
          "SBOM & Supply Chain",
          "Cloud IAM Auditing"
        ]
      },
      "clouds": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "enum": ["AWS", "Azure", "GCP", "Multi"]
        }
      },
      "type": {
        "type": "string",
        "enum": ["Open Source", "Commercial", "Freemium"]
      },
      "distinct": {
        "type": "string",
        "minLength": 16,
        "maxLength": 180
      },
      "compliance": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "minLength": 2
        }
      }
    }
  }
}
